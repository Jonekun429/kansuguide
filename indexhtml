      // 動画編集 - Premiere Pro
      { id: 201, name: "カット位置へジャンプ", cat: "動画編集(Premiere)", desc: "各クリップの端（カット位置）へ一気に移動します。", example: "↑ / ↓", keywords: ["ジャンプ", "カット", "移動"], related: [202, 203], type: "shortcut", difficulty: 2, popular: false },
      { id: 202, name: "5フレームずつ移動", cat: "動画編集(Premiere)", desc: "タイムラインのカーソルを5フレームずつ素早く移動させます。", example: "Shift + ← / →", keywords: ["移動", "フレーム", "早送り"], related: [201], type: "shortcut", difficulty: 2, popular: false },
      { id: 203, name: "イン / アウト点の指定", cat: "動画編集(Premiere)", desc: "動画の書き出しや削除の範囲を指定します。", example: "I / O", keywords: ["イン", "アウト", "範囲"], related: [201], type: "shortcut", difficulty: 2, popular: false },
      { id: 204, name: "リップル削除", cat: "動画編集(Premiere)", desc: "クリップの消去と空白の削除を同時に行います。", example: "Alt + Delete", keywords: ["削除", "リップル", "空白"], related: [205, 206], type: "shortcut", difficulty: 2, popular: false },
    ];

    function App() {
      const [search, setSearch] = useState("");
      const [cat, setCat] = useState("すべて");
      const [copiedId, setCopiedId] = useState(null);
      const [history, setHistory] = useState([]);

      // カテゴリ一覧（重複なし）
      const categories = useMemo(() => {
        const cats = new Set(DATABASE.map(d => d.cat));
        return ["すべて", ...Array.from(cats).sort()];
      }, []);

      // フィルタリング
      const filtered = useMemo(() => {
        return DATABASE.filter(item => {
          if (cat !== "すべて" && item.cat !== cat) return false;
          if (!search.trim()) return true;

          const q = search.toLowerCase();
          return (
            item.name.toLowerCase().includes(q) ||
            item.desc.toLowerCase().includes(q) ||
            item.keywords.some(k => k.toLowerCase().includes(q))
          );
        });
      }, [search, cat]);

      // コピー機能
      const handleCopy = (text, id) => {
        navigator.clipboard.writeText(text).then(() => {
          setCopiedId(id);
          const item = DATABASE.find(d => d.id === id);
          setHistory(prev => 
            [{ id, name: item?.name, text, time: new Date().toLocaleTimeString('ja-JP', { hour: '2-digit', minute: '2-digit' }) }, ...prev].slice(0, 15)
          );
          setTimeout(() => setCopiedId(null), 2000);
        }).catch(err => console.error("コピー失敗:", err));
      };

      // 関連関数取得
      const getRelated = useCallback((id) => {
        const item = DATABASE.find(d => d.id === id);
        return item?.related ? DATABASE.filter(d => item.related.includes(d.id)) : [];
      }, []);

      return (
        <div style={{ minHeight: '100vh', backgroundColor: 'var(--bg-page)' }}>
          {/* ヘッダー */}
          <header style={{ background: `linear-gradient(135deg, var(--primary-dark), var(--primary))`, color: 'white', padding: '24px 16px', boxShadow: '0 2px 8px rgba(0,0,0,0.1)' }}>
            <div style={{ maxWidth: '1200px', margin: '0 auto' }}>
              <h1 style={{ fontSize: '20px', fontWeight: 'bold', letterSpacing: '2.5px', margin: 0 }}>
                PCスキル学習＆実践ナビ
              </h1>
              <p style={{ fontSize: '14px', opacity: 0.9, margin: '8px 0 0 0', fontWeight: 400 }}>
                スプシ・動画編集・PC時短術まで網羅。あの関数に素早くたどり着く。
              </p>
            </div>
          </header>

          {/* メイン */}
          <main style={{ maxWidth: '1200px', margin: '0 auto', padding: '32px 16px' }}>
            {/* 検索セクション */}
            <div style={{ backgroundColor: 'var(--bg-card)', borderRadius: '12px', padding: '24px', marginBottom: '32px', border: `1px solid var(--border)`, boxShadow: '0 1px 3px rgba(0,0,0,0.05)' }}>
              <div style={{ display: 'grid', gridTemplateColumns: '1fr auto', gap: '16px', marginBottom: '12px' }}>
                <input
                  type="text"
                  placeholder="例: SUM, IF, 合計, 検索, スクショ, リップル..."
                  value={search}
                  onChange={(e) => setSearch(e.target.value)}
                  style={{
                    padding: '12px 16px',
                    border: `1px solid var(--border)`,
                    borderRadius: '8px',
                    fontSize: '14px',
                    fontFamily: 'inherit',
                    boxSizing: 'border-box'
                  }}
                />
                <select
                  value={cat}
                  onChange={(e) => setCat(e.target.value)}
                  style={{
                    padding: '12px 16px',
                    border: `1px solid var(--border)`,
                    borderRadius: '8px',
                    fontSize: '14px',
                    fontFamily: 'inherit',
                    backgroundColor: 'var(--bg-card)',
                    cursor: 'pointer',
                    minWidth: '180px'
                  }}
                >
                  {categories.map(c => (
                    <option key={c} value={c}>{c}</option>
                  ))}
                </select>
              </div>
              <p style={{ fontSize: '12px', color: 'var(--text-sub)', margin: 0 }}>
                {filtered.length} / {DATABASE.length} 件
              </p>
            </div>

            {/* 結果表示 */}
            <div style={{ display: 'grid', gridTemplateColumns: '1fr 300px', gap: '24px' }}>
              {/* 関数リスト */}
              <div>
                {filtered.length === 0 ? (
                  <div style={{ textAlign: 'center', padding: '48px 24px', backgroundColor: 'var(--bg-card)', borderRadius: '12px', border: `2px dashed var(--border)` }}>
                    <p style={{ color: 'var(--text-sub)', fontWeight: 600, margin: 0 }}>該当する項目が見つかりません</p>
                  </div>
                ) : (
                  <div style={{ display: 'flex', flexDirection: 'column', gap: '16px' }}>
                    {filtered.map(item => (
                      <div key={item.id} style={{ backgroundColor: 'var(--bg-card)', borderRadius: '12px', padding: '20px', border: `1px solid var(--border)`, borderLeft: `4px solid var(--primary)`, boxShadow: '0 1px 3px rgba(0,0,0,0.05)', transition: 'all 0.3s' }}>
                        <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'start', marginBottom: '12px' }}>
                          <h3 style={{ fontSize: '16px', fontWeight: 'bold', margin: 0, color: 'var(--primary-dark)' }}>
                            {item.name}
                          </h3>
                          <div style={{ display: 'flex', gap: '8px', alignItems: 'center', flexWrap: 'wrap', justifyContent: 'flex-end' }}>
                            {item.popular && (
                              <span style={{ fontSize: '11px', padding: '4px 10px', backgroundColor: '#FFE5E5', color: '#B36060', borderRadius: '12px', fontWeight: '700', whiteSpace: 'nowrap' }}>
                                ★ 人気
                              </span>
                            )}
                            <span style={{ fontSize: '12px', padding: '4px 12px', backgroundColor: 'var(--primary-light)', color: 'var(--primary-dark)', borderRadius: '20px', fontWeight: '600' }}>
                              {item.cat}
                            </span>
                          </div>
                        </div>
                        
                        {/* 難易度表示 */}
                        <div style={{ marginBottom: '12px' }}>
                          <span style={{ fontSize: '12px', fontWeight: '600', color: 'var(--text-sub)' }}>難易度：</span>
                          <span style={{ marginLeft: '8px', fontSize: '14px', letterSpacing: '2px' }}>
                            {item.difficulty === 1 ? '⭐ 初級' : item.difficulty === 2 ? '⭐⭐ 中級' : '⭐⭐⭐ 上級'}
                          </span>
                        </div>
                        
                        <p style={{ fontSize: '14px', color: 'var(--text-main)', marginBottom: '16px', lineHeight: '1.5' }}>
                          {item.desc}
                        </p>

                        {/* ユースケース表示 */}
                        {item.usecase && (
                          <div style={{ backgroundColor: '#FDF6EE', borderRadius: '8px', padding: '12px', marginBottom: '16px', border: '1px solid #E9A400', fontSize: '13px', lineHeight: '1.6', color: '#5D4C2C' }}>
                            <strong style={{ color: '#8A6030' }}>💡 こんなとき：</strong> {item.usecase}
                          </div>
                        )}

                        {/* コピーボタン */}
                        <div style={{ backgroundColor: 'var(--primary-light)', borderRadius: '8px', padding: '12px', display: 'flex', justifyContent: 'space-between', alignItems: 'center', gap: '12px', marginBottom: item.related?.length > 0 ? '16px' : 0 }}>
                          <code style={{ fontSize: '13px', fontFamily: 'monospace', color: 'var(--text-main)', flex: 1, whiteSpace: 'nowrap', overflow: 'hidden', textOverflow: 'ellipsis' }}>
                            {item.example}
                          </code>
                          <button
                            onClick={() => handleCopy(item.example, item.id)}
                            style={{
                              padding: '8px 16px',
                              backgroundColor: copiedId === item.id ? 'var(--primary)' : '#FFF',
                              color: copiedId === item.id ? '#FFF' : 'var(--text-main)',
                              border: `1px solid ${copiedId === item.id ? 'var(--primary)' : 'var(--border)'}`,
                              borderRadius: '6px',
                              cursor: 'pointer',
                              fontSize: '13px',
                              fontWeight: '600',
                              whiteSpace: 'nowrap',
                              transition: 'all 0.2s'
                            }}
                          >
                            {copiedId === item.id ? '✓ 完了' : 'コピー'}
                          </button>
                        </div>

                        {/* 関連関数 */}
                        {getRelated(item.id).length > 0 && (
                          <div style={{ backgroundColor: 'var(--primary-light)', borderRadius: '8px', padding: '12px', border: `1px solid var(--primary)` }}>
                            <p style={{ fontSize: '11px', fontWeight: '700', textTransform: 'uppercase', color: 'var(--primary-dark)', margin: '0 0 8px 0' }}>
                              関連関数
                            </p>
                            <div style={{ display: 'flex', flexWrap: 'wrap', gap: '8px' }}>
                              {getRelated(item.id).map(rel => (
                                <button
                                  key={rel.id}
                                  onClick={() => setSearch(rel.name)}
                                  style={{
                                    padding: '6px 12px',
                                    backgroundColor: 'var(--bg-card)',
                                    border: `1px solid var(--border)`,
                                    borderRadius: '6px',
                                    fontSize: '12px',
                                    fontWeight: '600',
                                    cursor: 'pointer',
                                    color: 'var(--text-main)',
                                    transition: 'all 0.2s'
                                  }}
                                  onMouseEnter={(e) => e.target.style.backgroundColor = 'var(--primary-light)'}
                                  onMouseLeave={(e) => e.target.style.backgroundColor = 'var(--bg-card)'}
                                >
                                  → {rel.name}
                                </button>
                              ))}
                            </div>
                          </div>
                        )}
                      </div>
                    ))}
                  </div>
                )}
              </div>

              {/* サイドバー：コピー履歴 */}
              <div style={{ backgroundColor: 'var(--bg-card)', borderRadius: '12px', padding: '20px', border: `1px solid var(--border)`, height: 'fit-content', position: 'sticky', top: '20px' }}>
                <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', marginBottom: '16px', paddingBottom: '12px', borderBottom: `1px solid var(--border)` }}>
                  <h2 style={{ fontSize: '14px', fontWeight: 'bold', margin: 0, color: 'var(--text-main)' }}>
                    📋 コピー履歴
                  </h2>
                  {history.length > 0 && (
                    <button
                      onClick={() => setHistory([])}
                      style={{
                        fontSize: '12px',
                        color: 'var(--text-sub)',
                        background: 'none',
                        border: 'none',
                        cursor: 'pointer',
                        padding: '4px 8px',
                        transition: 'color 0.2s'
                      }}
                      onMouseEnter={(e) => e.target.style.color = 'var(--danger)'}
                      onMouseLeave={(e) => e.target.style.color = 'var(--text-sub)'}
                    >
                      クリア
                    </button>
                  )}
                </div>

                <div style={{ maxHeight: '400px', overflowY: 'auto' }} className="custom-scrollbar">
                  {history.length === 0 ? (
                    <p style={{ fontSize: '12px', color: 'var(--text-sub)', textAlign: 'center', margin: '24px 0' }}>
                      まだ履歴がありません
                    </p>
                  ) : (
                    <div style={{ display: 'flex', flexDirection: 'column', gap: '8px' }}>
                      {history.map((item, idx) => (
                        <div key={idx} style={{ backgroundColor: 'var(--bg-page)', borderRadius: '6px', padding: '8px', fontSize: '12px', border: `1px solid var(--border)` }}>
                          <div style={{ display: 'flex', justifyContent: 'space-between', marginBottom: '4px' }}>
                            <strong style={{ color: 'var(--text-main)', fontSize: '13px' }}>{item.name}</strong>
                            <span style={{ color: 'var(--text-sub)', fontSize: '11px' }}>{item.time}</span>
                          </div>
                          <code style={{ fontSize: '11px', color: 'var(--text-sub)', fontFamily: 'monospace', whiteSpace: 'pre-wrap', wordBreak: 'break-all' }}>
                            {item.text}
                          </code>
                        </div>
                      ))}
                    </div>
                  )}
                </div>
              </div>
            </div>
          </main>
        </div>
      );
    }

    const root = ReactDOM.createRoot(document.getElementById('root'));
    root.render(<App />);
  </script>
</body>
</html>
